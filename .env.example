# Agentbot Open Source — Environment Variables
# Copy this file to .env and fill in your own values.
# NEVER commit .env files — they're in .gitignore by default.

# ─── Required ───────────────────────────────────────
# Your OpenClaw API key (get from your OpenClaw instance)
INTERNAL_API_KEY=your-api-key-here

# ─── AI Provider (BYOK — pick one) ─────────────────
# Uncomment ONE of these and add your key:
# OPENROUTER_API_KEY=sk-or-v1-...
# ANTHROPIC_API_KEY=sk-ant-...
# OPENAI_API_KEY=sk-...
# GEMINI_API_KEY=AIza...
# GROQ_API_KEY=gsk_...

# ─── Telegram (optional) ───────────────────────────
# TELEGRAM_BOT_TOKEN=123456:ABC-DEF...

# ─── Database ───────────────────────────────────────
DATABASE_URL=postgresql://agentbot:agentbot_local_dev@localhost:5432/agentbot
REDIS_URL=redis://localhost:6379

# ─── Server ─────────────────────────────────────────
NODE_ENV=development
PORT=3001
AGENTS_DOMAIN=agents.localhost
AGENTS_BASE_PORT=19000

# ─── Wallet (optional — CDP integration) ───────────
# CDP_API_KEY_NAME=...
# CDP_PRIVATE_KEY=...
# CDP_WALLET_SECRET=...
# WALLET_ENCRYPTION_KEY=...

# ─── Frontend ───────────────────────────────────────
# NEXT_PUBLIC_APP_URL=http://localhost:3000
# NEXTAUTH_URL=http://localhost:3000
# NEXTAUTH_SECRET=...

# ─── Production Only ────────────────────────────────
# ALLOWED_ORIGINS=https://your-domain.com
# RENDER_API_KEY=rnd_...
