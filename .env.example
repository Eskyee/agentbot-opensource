# Agentbot Environment Variables
# Copy to .env.local (frontend) or .env (backend) and fill in your values
# REQUIRED = must be set | OPTIONAL = can be left blank

# ─── Database ───────────────────────────────────────────────────────────────────
# REQUIRED
DATABASE_URL=postgresql://agentbot:password@localhost:5432/agentbot

# ─── Auth (NextAuth) ─────────────────────────────────────────────────────────────
# REQUIRED
NEXTAUTH_URL=http://localhost:3000
# REQUIRED — generate with: openssl rand -base64 32
NEXTAUTH_SECRET=change-me-to-a-random-secret

# OPTIONAL: Google OAuth
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# OPTIONAL: Discord OAuth
DISCORD_CLIENT_ID=
DISCORD_CLIENT_SECRET=

# ─── OpenClaw Gateway ────────────────────────────────────────────────────────────
# REQUIRED: URL of your OpenClaw managed gateway
NEXT_PUBLIC_OPENCLAW_GATEWAY_URL=https://openclaw-gw-ui-production.up.railway.app
# REQUIRED: Platform-level auth token for OpenClaw gateway
OPENCLAW_GATEWAY_TOKEN=

# ─── Backend API ─────────────────────────────────────────────────────────────────
# REQUIRED — generate with: openssl rand -hex 32
INTERNAL_API_KEY=change-me-to-a-random-key
# REQUIRED
NEXT_PUBLIC_APP_URL=http://localhost:3000
# OPTIONAL: Comma-separated admin email addresses
ADMIN_EMAILS=admin@yourdomain.com
# OPTIONAL
DATA_DIR=/opt/agentbot/data
# OPTIONAL: Base domain for agent subdomains
AGENTS_DOMAIN=agents.yourdomain.com

# ─── AI Providers (at least one required) ────────────────────────────────────────
# RECOMMENDED: OpenRouter gives access to all models with one key
OPENROUTER_API_KEY=
# OPTIONAL: Direct provider keys
ANTHROPIC_API_KEY=
OPENAI_API_KEY=
GEMINI_API_KEY=
GROQ_API_KEY=

# ─── Payments (Stripe) ───────────────────────────────────────────────────────────
# REQUIRED for subscriptions
STRIPE_SECRET_KEY=
STRIPE_PUBLISHABLE_KEY=
STRIPE_WEBHOOK_SECRET=
# Plan price IDs (create in Stripe dashboard)
STRIPE_PRICE_ID_UNDERGROUND=
STRIPE_PRICE_ID_COLLECTIVE=
STRIPE_PRICE_ID_LABEL=

# ─── Agent Wallets (Coinbase CDP) ────────────────────────────────────────────────
# REQUIRED for USDC wallets on Base
CDP_API_KEY_ID=
CDP_API_KEY_SECRET=
CDP_PROJECT_ID=

# ─── Skills ──────────────────────────────────────────────────────────────────────
# OPTIONAL: Replicate API — enables visual-synthesizer skill
REPLICATE_API_TOKEN=

# ─── Docker / Containers ─────────────────────────────────────────────────────────
# OPTIONAL: Override default OpenClaw image
OPENCLAW_IMAGE=ghcr.io/openclaw/openclaw:latest
# OPTIONAL: Base port for agent containers (increments per agent)
AGENTS_BASE_PORT=19000

# ─── Redis ───────────────────────────────────────────────────────────────────────
# REQUIRED
REDIS_URL=redis://localhost:6379

# ─── Vercel KV (optional Redis alternative on Vercel) ────────────────────────────
KV_REST_API_URL=
KV_REST_API_TOKEN=

# ─── Webhooks ────────────────────────────────────────────────────────────────────
# OPTIONAL: Mux video
MUX_WEBHOOK_SECRET=
# OPTIONAL: WhatsApp Business
WHATSAPP_WEBHOOK_SECRET=
# OPTIONAL: Telegram bot
TELEGRAM_BOT_TOKEN=

# ─── Security ────────────────────────────────────────────────────────────────────
# Kill switch — set to "true" to block all provisioning (incident response)
KILL_SWITCH=false
