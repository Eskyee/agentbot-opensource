# Agentbot Environment Variables
# Copy this file to .env and fill in your values

# ─── Database ───
DATABASE_URL=postgresql://agentbot:password@localhost:5432/agentbot

# ─── Auth ───
NEXTAUTH_URL=http://localhost:3000
NEXTAUTH_SECRET=change-me-to-a-random-secret

# ─── Backend ───
INTERNAL_API_KEY=change-me-to-a-random-key
DATA_DIR=/opt/agentbot/data
AGENTS_DOMAIN=agents.yourdomain.com
ADMIN_EMAILS=admin@yourdomain.com

# ─── AI Providers (choose one) ───
OPENROUTER_API_KEY=
GEMINI_API_KEY=
GROQ_API_KEY=
ANTHROPIC_API_KEY=
OPENAI_API_KEY=

# ─── Streaming (optional) ───
STREAMING_API_KEY=
STREAMING_API_SECRET=

# ─── Docker ───
OPENCLAW_IMAGE=ghcr.io/openclaw/openclaw:latest
AGENTS_BASE_PORT=19000

# ─── Redis ───
REDIS_URL=redis://localhost:6379
