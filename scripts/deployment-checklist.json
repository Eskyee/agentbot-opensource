        "title": "Railway Services",
        "items": [
          { "id": "railway-1", "task": "Confirm linked project/service status", "command": "railway status", "status": "pending", "required": true },
          { "id": "railway-2", "task": "Verify agentbot backend health", "command": "curl https://agentbot-prod-production.up.railway.app/health", "expect": "200 ok", "status": "pending", "required": true },
          { "id": "railway-3", "task": "Verify Borg / soul health", "command": "curl https://borg-0-production.up.railway.app/health", "expect": "200 ok", "status": "pending", "required": true },
          { "id": "railway-4", "task": "Verify x402 gateway health", "command": "curl https://x402-gateway-production.up.railway.app/health", "expect": "200 ok", "status": "pending", "required": true },
          { "id": "railway-5", "task": "Verify shared OpenClaw UI health if used by current surfaces", "command": "curl https://openclaw-gw-ui-production.up.railway.app/health", "expect": "200 ok", "status": "pending", "required": false }
        ]
      }
