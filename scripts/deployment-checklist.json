{
  "deploymentChecklist": {
    "metadata": {
      "version": "1.0.0",
      "lastUpdated": "2026-03-23",
      "template": "production"
    },
    "preDeployment": {
      "codeQuality": {
        "title": "Code Quality & Validation",
        "items": [
          { "id": "cd-1", "task": "Run pre-deployment validation script", "command": "node scripts/pre-deployment-validation.js", "status": "pending", "required": true },
          { "id": "cd-2", "task": "Pull latest main branch", "command": "git pull origin main", "status": "pending", "required": true },
          { "id": "cd-3", "task": "Verify git status is clean", "command": "git status --porcelain", "expect": "empty", "status": "pending", "required": true },
          { "id": "cd-4", "task": "Run backend tests", "command": "cd agentbot-backend && npm test", "status": "pending", "required": true },
          { "id": "cd-5", "task": "Run frontend tests", "command": "cd web && npm test", "status": "pending", "required": true },
          { "id": "cd-6", "task": "Run E2E tests", "command": "cd web && npx playwright test", "status": "pending", "required": true },
          { "id": "cd-7", "task": "Build backend", "command": "cd agentbot-backend && npm run build", "status": "pending", "required": true },
          { "id": "cd-8", "task": "Build frontend", "command": "cd web && npm run build", "status": "pending", "required": true }
        ]
      },
      "environment": {
        "title": "Environment Configuration",
        "items": [
          { "id": "env-1", "task": "Verify Vercel secrets configured", "check": "vercel dashboard", "status": "pending", "required": true },
          { "id": "env-2", "task": "Verify Render secrets configured", "check": "render dashboard", "status": "pending", "required": true },
          { "id": "env-3", "task": "Verify NEXTAUTH_SECRET set", "check": "vercel env vars", "status": "pending", "required": true },
          { "id": "env-4", "task": "Verify DATABASE_URL set", "check": "vercel + render env vars", "status": "pending", "required": true },
          { "id": "env-5", "task": "Verify STRIPE_SECRET_KEY set", "check": "vercel + render env vars", "status": "pending", "required": true },
          { "id": "env-6", "task": "Verify STRIPE_WEBHOOK_SECRET set", "check": "vercel + render env vars", "status": "pending", "required": true },
          { "id": "env-7", "task": "Verify OPENROUTER_API_KEY set", "check": "vercel + render env vars", "status": "pending", "required": true },
          { "id": "env-8", "task": "Verify ADMIN_EMAILS set", "check": "vercel + render env vars", "status": "pending", "required": true }
        ]
      },
      "database": {
        "title": "Database & Migrations",
        "items": [
          { "id": "db-1", "task": "Verify migrations directory exists", "check": "web/prisma/migrations/", "status": "pending", "required": true },
          { "id": "db-2", "task": "Verify schema file exists", "check": "web/prisma/schema.prisma", "status": "pending", "required": true },
          { "id": "db-3", "task": "Test database connection locally", "command": "cd web && npx prisma db push --skip-generate", "status": "pending", "required": true },
          { "id": "db-4", "task": "Verify database backups enabled", "check": "render dashboard", "status": "pending", "required": true },
          { "id": "db-5", "task": "Verify PITR enabled", "check": "render dashboard", "status": "pending", "required": false }
        ]
      }
    },
    "deployment": {
      "git": {
        "title": "Git & CI/CD",
        "items": [
          { "id": "git-1", "task": "Commit all changes", "command": "git add . && git commit -m 'chore: deployment preparation'", "status": "pending", "required": true },
          { "id": "git-2", "task": "Push to main branch", "command": "git push origin main", "status": "pending", "required": true },
          { "id": "git-3", "task": "Monitor GitHub Actions", "check": "github actions", "status": "pending", "required": true },
          { "id": "git-4", "task": "Verify backend build succeeds", "check": "github actions logs", "status": "pending", "required": true },
          { "id": "git-5", "task": "Verify frontend build succeeds", "check": "github actions logs", "status": "pending", "required": true },
          { "id": "git-6", "task": "Verify validation passes", "check": "github actions logs", "status": "pending", "required": true }
        ]
      },
