{
  "deploymentChecklist": {
    "metadata": {
      "version": "2.0.0",
      "lastUpdated": "2026-04-02",
      "template": "production"
    },
    "preDeployment": {
      "codeQuality": {
        "title": "Code Quality & Validation",
        "items": [
          { "id": "cd-1", "task": "Run pre-deployment validation script", "command": "node scripts/pre-deployment-validation.js", "status": "pending", "required": true },
          { "id": "cd-2", "task": "Verify git status is clean", "command": "git status --porcelain", "expect": "empty", "status": "pending", "required": true },
          { "id": "cd-3", "task": "Run backend type-check", "command": "cd agentbot-backend && npx tsc --noEmit", "status": "pending", "required": true },
          { "id": "cd-4", "task": "Run backend tests", "command": "cd agentbot-backend && npm test", "status": "pending", "required": true },
          { "id": "cd-5", "task": "Build backend", "command": "cd agentbot-backend && npm run build", "status": "pending", "required": true },
          { "id": "cd-6", "task": "Build frontend from web root", "command": "cd web && npm run build", "status": "pending", "required": true },
          { "id": "cd-7", "task": "Run E2E tests if Playwright is configured", "command": "cd web && npx playwright test", "status": "pending", "required": false }
        ]
      },
      "environment": {
        "title": "Environment Configuration",
        "items": [
          { "id": "env-1", "task": "Verify Vercel project uses web as Root Directory", "check": "vercel project settings", "status": "pending", "required": true },
          { "id": "env-2", "task": "Verify Vercel production env vars", "check": "vercel dashboard", "status": "pending", "required": true },
          { "id": "env-3", "task": "Verify Railway production env vars for agentbot-prod", "check": "railway dashboard", "status": "pending", "required": true },
          { "id": "env-4", "task": "Verify Railway production env vars for tempo-x402 / Borg", "check": "railway dashboard", "status": "pending", "required": true },
          { "id": "env-5", "task": "Verify Railway production env vars for x402 gateway", "check": "railway dashboard", "status": "pending", "required": true },
          { "id": "env-6", "task": "Verify NEXTAUTH_SECRET set where auth runs", "check": "deployment env vars", "status": "pending", "required": true },
          { "id": "env-7", "task": "Verify DATABASE_URL set where Prisma-backed routes run", "check": "deployment env vars", "status": "pending", "required": true },
          { "id": "env-8", "task": "Verify X402_GATEWAY_URL and SOUL_SERVICE_URL point to live Railway hosts", "check": "deployment env vars", "status": "pending", "required": true },
          { "id": "env-9", "task": "Verify TEMPO_FEE_PAYER_KEY if wallet sponsorship is enabled", "check": "deployment env vars", "status": "pending", "required": false }
        ]
      }
    },
    "deployment": {
