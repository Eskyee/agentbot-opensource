        "title": "Post-Deployment Verification",
        "items": [
          { "id": "pd-1", "task": "Test homepage loads", "check": "https://agentbot.sh", "status": "pending", "required": true },
          { "id": "pd-2", "task": "Test login page accessible", "check": "https://agentbot.sh/login", "status": "pending", "required": true },
          { "id": "pd-3", "task": "Test dashboard after login", "check": "manual test after login", "status": "pending", "required": true },
          { "id": "pd-4", "task": "Test x402 dashboard and colony dashboard", "check": "manual test", "status": "pending", "required": true },
          { "id": "pd-5", "task": "Verify wallet dashboard loads without crashes", "check": "manual test", "status": "pending", "required": true },
          { "id": "pd-6", "task": "Verify browser console has no new errors", "check": "browser dev tools", "status": "pending", "required": true }
        ]
      },
      "monitoring": {
        "title": "Monitoring Setup",
        "items": [
          { "id": "mon-1", "task": "Check Railway logs for backend and Borg errors", "check": "railway logs", "status": "pending", "required": true },
          { "id": "mon-2", "task": "Check Vercel logs for production errors", "check": "vercel dashboard logs", "status": "pending", "required": true },
          { "id": "mon-3", "task": "Verify auth and database-backed routes are healthy", "check": "manual + dashboards", "status": "pending", "required": true },
          { "id": "mon-4", "task": "Verify wallet sponsorship and x402 routes if enabled", "check": "manual + logs", "status": "pending", "required": false }
        ]
      },
      "documentation": {
        "title": "Documentation & Records",
        "items": [
          { "id": "doc-1", "task": "Record deployment date/time", "check": "deployment log", "status": "pending", "required": true },
          { "id": "doc-2", "task": "Record deployed commit", "check": "git commit hash", "status": "pending", "required": true },
          { "id": "doc-3", "task": "Document any incidents or degraded services", "check": "deployment log", "status": "pending", "required": true },
          { "id": "doc-4", "task": "Update platform docs if service URLs changed", "check": "docs/CURRENT_PLATFORM_STATE.md", "status": "pending", "required": true }
        ]
      }
    },
    "rollback": {
      "emergency": {
        "title": "Emergency Rollback (If Needed)",
        "items": [
          { "id": "rb-1", "task": "Confirm rollback need from live impact", "check": "monitoring and user impact", "status": "pending", "required": true },
          { "id": "rb-2", "task": "Rollback Vercel deployment", "command": "npx vercel rollback", "status": "pending", "required": true },
          { "id": "rb-3", "task": "Rollback or redeploy affected Railway service", "check": "railway dashboard or cli", "status": "pending", "required": true },
          { "id": "rb-4", "task": "Re-run core health checks", "command": "curl https://agentbot-prod-production.up.railway.app/health && curl https://borg-0-production.up.railway.app/health && curl https://x402-gateway-production.up.railway.app/health", "status": "pending", "required": true },
          { "id": "rb-5", "task": "Verify production web recovers", "command": "curl -I https://agentbot.sh", "status": "pending", "required": true },
          { "id": "rb-6", "task": "Document rollback action and cause", "check": "rollback log", "status": "pending", "required": true }
        ]
      }
