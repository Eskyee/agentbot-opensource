        "title": "Git & CI/CD",
        "items": [
          { "id": "git-1", "task": "Push reviewed changes to staging first when possible", "command": "git push origin HEAD:staging", "status": "pending", "required": false },
          { "id": "git-2", "task": "Push deployable branch", "command": "git push origin main", "status": "pending", "required": true },
          { "id": "git-3", "task": "Verify GitHub Actions complete", "check": "github actions", "status": "pending", "required": true },
          { "id": "git-4", "task": "Confirm backend build/test jobs pass", "check": "github actions logs", "status": "pending", "required": true },
          { "id": "git-5", "task": "Confirm frontend build job passes", "check": "github actions logs", "status": "pending", "required": true }
        ]
      },
      "vercel": {
        "title": "Vercel Deployment",
        "items": [
          { "id": "vercel-1", "task": "Monitor latest preview or production deployment", "check": "vercel dashboard", "status": "pending", "required": true },
          { "id": "vercel-2", "task": "Verify deployment reaches Ready", "check": "vercel dashboard", "status": "pending", "required": true },
          { "id": "vercel-3", "task": "Verify custom domain is active", "check": "vercel dashboard", "status": "pending", "required": true },
          { "id": "vercel-4", "task": "Test frontend health surface", "command": "curl -I https://agentbot.sh", "expect": "200", "status": "pending", "required": true }
        ]
      },
