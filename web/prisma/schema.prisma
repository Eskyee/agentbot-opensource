generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id                    String           @id @default(cuid())
  name                  String?
  email                 String?          @unique
  emailVerified         DateTime?
  image                 String?
  password              String?
  role                  String           @default("user")
  storageLimit          Int              @default(10)
  plan                  String           @default("free")
  stripeCustomerId      String?
  stripeSubscriptionId  String?
  subscriptionEndDate   DateTime?
  subscriptionStartDate DateTime?
  subscriptionStatus    String           @default("inactive")
  openclawUrl           String?
  openclawInstanceId    String?
  referralCode          String?          @unique
  referralCredits       Int              @default(0)
  referredBy            String?
  trialEndsAt           DateTime?
  accounts              Account[]
  agents                Agent[]
  agentFiles            AgentFile[]
  agentMemories         AgentMemory[]
  agentSwarms           AgentSwarm[]
  apiKeys               ApiKey[]
  calendarToken         CalendarToken?
  installedSkills       InstalledSkill[]
  pairedDevices         PairedDevice[]
  userSettings          UserSetting[]
  referredByUser        Referral?        @relation("Referred")
  referrals             Referral[]       @relation("Referrer")
  scheduledTasks        ScheduledTask[]
  sessions              Session[]
  wallets               Wallet[]
  workflows             Workflow[]
  passkeyCredentials    PasskeyCredential[]
  passkeyChallenges     PasskeyChallenge[]
  notifications         Notification[]
  buddies               Buddy[]
}

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String?
  access_token      String?
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String?
  session_state     String?
  user              User    @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}

model Agent {
  id              String           @id @default(cuid())
  userId          String
  name            String
  model           String?
  status          String           @default("pending")
  websocketUrl    String?
  config          Json?
  createdAt       DateTime         @default(now())
  updatedAt       DateTime         @updatedAt
  tier            String           @default("free")
  user            User             @relation(fields: [userId], references: [id], onDelete: Cascade)
  files           AgentFile[]
  memories        AgentMemory[]
  installedSkills InstalledSkill[]
  scheduledTasks  ScheduledTask[]
  showcaseOptIn       Boolean          @default(false)
  showcaseDescription String           @default("")

  @@index([userId])
  @@index([status])
  @@index([userId, status])
}

model ScheduledTask {
  id           String    @id @default(cuid())
  userId       String
  agentId      String
  name         String
  description  String?
  cronSchedule String
  prompt       String
  enabled      Boolean   @default(true)
  lastRun      DateTime?
  nextRun      DateTime?
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt
  agent        Agent     @relation(fields: [agentId], references: [id], onDelete: Cascade)
  user         User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([agentId])
  @@index([enabled, nextRun])
}

model AgentMemory {
  id        String   @id @default(cuid())
  userId    String
  agentId   String
  key       String
  value     String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  agent     Agent    @relation(fields: [agentId], references: [id], onDelete: Cascade)
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, agentId, key])
  @@index([agentId])
}

model AgentFile {
  id        String   @id @default(cuid())
  userId    String
  agentId   String
  filename  String
  path      String?
  size      Int
  mimeType  String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  url       String?
  userEmail String?
  agent     Agent    @relation(fields: [agentId], references: [id], onDelete: Cascade)
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([agentId])
}

model Skill {
  id              String           @id @default(cuid())
  name            String
  description     String
  category        String
  code            String
  author          String
  downloads       Int              @default(0)
  rating          Float            @default(0)
  featured        Boolean          @default(false)
  mcpConfig       Json?            // MCP (Model Context Protocol) configuration
  mcpEnabled      Boolean          @default(false)
  createdAt       DateTime         @default(now())
  updatedAt       DateTime         @updatedAt
  installedSkills InstalledSkill[]

  @@index([category])
  @@index([featured])
  @@index([mcpEnabled])
}

model InstalledSkill {
  id        String   @id @default(cuid())
  userId    String
  agentId   String
  skillId   String
  enabled   Boolean  @default(true)
  createdAt DateTime @default(now())
  agent     Agent    @relation(fields: [agentId], references: [id], onDelete: Cascade)
  skill     Skill    @relation(fields: [skillId], references: [id], onDelete: Cascade)
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, agentId, skillId])
  @@index([userId])
  @@index([agentId])
}

model PasskeyCredential {
  id           String    @id @default(cuid())
  userId       String
  credentialId String    @unique
  publicKey    String
  transports   String?
  name         String?
  signCount    BigInt    @default(0)
  createdAt    DateTime  @default(now())
  lastUsedAt   DateTime?
  user         User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
}

model PasskeyChallenge {
  id           String   @id @default(cuid())
  challenge    String   @unique
  type         String
  userId       String?
  credentialId String?
  rpId         String
  origin       String
  expiresAt    DateTime
  createdAt    DateTime @default(now())
  user         User?    @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([type])
  @@index([userId])
}

model AgentSwarm {
  id          String   @id @default(cuid())
  userId      String
  name        String
  description String?
  agents      String
  enabled     Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
}

model WorkflowNode {
  id         String   @id @default(cuid())
  workflowId String
  type       String
  config     String
  position   String
  createdAt  DateTime @default(now())
  workflow   Workflow @relation(fields: [workflowId], references: [id], onDelete: Cascade)

  @@index([workflowId])
}

model Workflow {
  id          String         @id @default(cuid())
  userId      String
  name        String
  description String?
  enabled     Boolean        @default(true)
  createdAt   DateTime       @default(now())
  updatedAt   DateTime       @updatedAt
  user        User           @relation(fields: [userId], references: [id], onDelete: Cascade)
  nodes       WorkflowNode[]

  @@index([userId])
}

model Wallet {
  id                  String   @id @default(cuid())
  userId              String
  address             String   @unique
  walletSeedEncrypted String
  network             String   @default("base-sepolia")
  walletType          String   @default("cdp")
  createdAt           DateTime @default(now())
  updatedAt           DateTime @updatedAt
  user                User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([address])
}

model Referral {
  id              String   @id @default(cuid())
  referrerId      String
  referredId      String   @unique
  referralCode    String
  discountApplied Boolean  @default(false)
  referrerReward  Boolean  @default(false)
  createdAt       DateTime @default(now())
  referred        User     @relation("Referred", fields: [referredId], references: [id])
  referrer        User     @relation("Referrer", fields: [referrerId], references: [id])

  @@index([referrerId])
}

model ApiKey {
  id        String    @id @default(cuid())
  userId    String
  name      String
  keyHash   String    @unique
  keyPrefix String
  lastUsed  DateTime?
  createdAt DateTime  @default(now())
  user      User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
}

model CalendarToken {
  id           String   @id @default(cuid())
  userId       String   @unique
  accessToken  String   // AES-256-GCM encrypted
  refreshToken String   // AES-256-GCM encrypted
  calendarId   String   @default("primary")
  timezone     String   @default("UTC")
  expiresAt    DateTime?
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
}

model Notification {
  id        String   @id @default(cuid())
  userId    String
  type      String   // achievement | badge | referral | system | agent | message | billing
  title     String
  message   String
  read      Boolean  @default(false)
  data      Json?    // Additional data (badge info, referral details, etc.)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([userId, read])
  @@index([createdAt])
}

model PairedDevice {
  id        String   @id @default(cuid())
  userId    String
  name      String
  ip        String
  status    String   @default("pending") // pending | approved | denied | revoked
  firstSeen DateTime @default(now())
  lastSeen  DateTime @default(now())
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([userId, status])
}

model UserSetting {
  id        String   @id @default(cuid())
  userId    String
  key       String
  value     String   // AES-256-GCM encrypted
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, key])
  @@index([userId])
}

model Buddy {
  id         String   @id @default(cuid())
  userId     String
  name       String
  type       String   // crab | robot | ghost | dragon | alien
  level      Int      @default(1)
  xp         Int      @default(0)
  energy     Int      @default(100)
  happiness  Int      @default(100)
  lastFed    DateTime @default(now())
  lastPlayed DateTime @default(now())
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt
  user       User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
}

model agent_registrations {
  user_id       String    @id
  mode          String    @default("home")
  gateway_token String?
  registered_at DateTime? @default(now()) @db.Timestamptz(6)
  last_seen     DateTime? @default(now()) @db.Timestamptz(6)
  status        String    @default("active")
}

model agents {
  id                    Int                     @id @default(autoincrement())
  user_id               Int?
  name                  String
  config                Json?                   @default("{}")
  status                String?                 @default("active")
  created_at            DateTime?               @default(now()) @db.Timestamptz(6)
  updated_at            DateTime?               @default(now()) @db.Timestamptz(6)
  users                 users?                  @relation(fields: [user_id], references: [id], onDelete: Cascade, onUpdate: NoAction)
  bookings              bookings[]
  deployments           deployments[]
  events                events[]
  model_metrics         model_metrics[]
  royalty_splits        royalty_splits[]
  social_campaigns      social_campaigns[]
  treasury_transactions treasury_transactions[]
  wallets               wallets[]

  @@index([status], map: "idx_agents_status")
  @@index([user_id], map: "idx_agents_user_id")
}

model api_keys {
  id           BigInt    @id @default(autoincrement())
  key_hash     String    @unique
  user_id      String
  plan         String    @default("solo")
  label        String?
  revoked      Boolean   @default(false)
  last_used_at DateTime? @db.Timestamptz(6)
  created_at   DateTime? @default(now()) @db.Timestamptz(6)

  @@index([user_id], map: "idx_api_keys_user")
}

model bookings {
  id                  Int       @id @default(autoincrement())
  agent_id            Int?
  event_id            Int?
  status              String?   @default("pending")
  proposed_price_usdc Decimal?  @db.Decimal
  final_price_usdc    Decimal?  @db.Decimal
  created_at          DateTime? @default(now()) @db.Timestamptz(6)
  updated_at          DateTime? @default(now()) @db.Timestamptz(6)
  agents              agents?   @relation(fields: [agent_id], references: [id], onDelete: NoAction, onUpdate: NoAction)
  events              events?   @relation(fields: [event_id], references: [id], onDelete: NoAction, onUpdate: NoAction)

  @@index([agent_id], map: "idx_bookings_agent_id")
  @@index([event_id], map: "idx_bookings_event_id")
}

model container_metrics {
  id             BigInt   @id @default(autoincrement())
  user_id        String
  container_name String
  cpu_percent    Decimal? @db.Decimal
  mem_percent    Decimal? @db.Decimal
  message_count  Int?     @default(0)
  error_count    Int?     @default(0)
  sampled_at     DateTime @default(now()) @db.Timestamptz(6)

  @@index([user_id, sampled_at(sort: Desc)], map: "idx_container_metrics_user_time")
}

model deployments {
  id                Int       @id @default(autoincrement())
  user_id           Int?
  agent_id          Int?
  status            String?   @default("pending")
  render_service_id String?
  subdomain         String?
  created_at        DateTime? @default(now()) @db.Timestamptz(6)
  updated_at        DateTime? @default(now()) @db.Timestamptz(6)
  agents            agents?   @relation(fields: [agent_id], references: [id], onDelete: NoAction, onUpdate: NoAction)
  users             users?    @relation(fields: [user_id], references: [id], onDelete: NoAction, onUpdate: NoAction)

  @@index([agent_id], map: "idx_deployments_agent_id")
  @@index([user_id], map: "idx_deployments_user_id")
}

model events {
  id                Int        @id @default(autoincrement())
  agent_id          Int?
  name              String
  description       String?
  venue             String?
  event_date        DateTime?  @db.Timestamptz(6)
  ticket_price_usdc Decimal?   @default(0) @db.Decimal
  total_tickets     Int?       @default(0)
  tickets_sold      Int?       @default(0)
  created_at        DateTime?  @default(now()) @db.Timestamptz(6)
  bookings          bookings[]
  agents            agents?    @relation(fields: [agent_id], references: [id], onDelete: Cascade, onUpdate: NoAction)

  @@index([agent_id], map: "idx_events_agent_id")
}

model invite_codes {
  code       String    @id
  used       Boolean   @default(false)
  used_at    DateTime? @db.Timestamptz(6)
  created_by String?
  created_at DateTime? @default(now()) @db.Timestamptz(6)

  @@index([used], map: "idx_invite_codes_used")
}

model model_metrics {
  id            Int       @id @default(autoincrement())
  user_id       Int?
  agent_id      Int?
  model         String
  input_tokens  Int?      @default(0)
  output_tokens Int?      @default(0)
  cost_usdc     Decimal?  @default(0) @db.Decimal
  created_at    DateTime? @default(now()) @db.Timestamptz(6)
  agents        agents?   @relation(fields: [agent_id], references: [id], onDelete: NoAction, onUpdate: NoAction)
  users         users?    @relation(fields: [user_id], references: [id], onDelete: NoAction, onUpdate: NoAction)

  @@index([user_id, created_at(sort: Desc)], map: "idx_model_metrics_user")
}

model royalty_recipients {
  id             Int             @id @default(autoincrement())
  split_id       Int?
  address        String
  percentage     Decimal         @db.Decimal
  paid           Boolean?        @default(false)
  created_at     DateTime?       @default(now()) @db.Timestamptz(6)
  royalty_splits royalty_splits? @relation(fields: [split_id], references: [id], onDelete: Cascade, onUpdate: NoAction)

  @@index([split_id], map: "idx_royalty_recipients_split_id")
}

model royalty_splits {
  id                 Int                  @id @default(autoincrement())
  agent_id           Int?
  name               String
  total_amount_usdc  Decimal?             @default(0) @db.Decimal
  status             String?              @default("pending")
  created_at         DateTime?            @default(now()) @db.Timestamptz(6)
  royalty_recipients royalty_recipients[]
  agents             agents?              @relation(fields: [agent_id], references: [id], onDelete: Cascade, onUpdate: NoAction)

  @@index([agent_id], map: "idx_royalty_splits_agent_id")
}

model social_amplifications {
  id                 Int               @id @default(autoincrement())
  campaign_id        Int?
  partner_agent_id   String?
  reward_amount_usdc Decimal?          @default(0) @db.Decimal
  status             String?           @default("requested")
  post_url           String?
  engagement_count   Int?              @default(0)
  created_at         DateTime?         @default(now()) @db.Timestamptz(6)
  social_campaigns   social_campaigns? @relation(fields: [campaign_id], references: [id], onDelete: Cascade, onUpdate: NoAction)

  @@index([campaign_id], map: "idx_social_amplifications_campaign_id")
}

model social_campaigns {
  id                    Int                     @id @default(autoincrement())
  user_id               Int?
  agent_id              Int?
  platform              String
  content               String?
  status                String?                 @default("active")
  created_at            DateTime?               @default(now()) @db.Timestamptz(6)
  social_amplifications social_amplifications[]
  agents                agents?                 @relation(fields: [agent_id], references: [id], onDelete: NoAction, onUpdate: NoAction)
  users                 users?                  @relation(fields: [user_id], references: [id], onDelete: NoAction, onUpdate: NoAction)

  @@index([agent_id], map: "idx_social_campaigns_agent_id")
  @@index([user_id], map: "idx_social_campaigns_user_id")
}

model treasury_transactions {
  id          Int       @id @default(autoincrement())
  user_id     Int?
  agent_id    Int?
  category    String
  action      String?
  amount_usdc Decimal?  @default(0) @db.Decimal
  metadata    Json?     @default("{}")
  created_at  DateTime? @default(now()) @db.Timestamptz(6)
  agents      agents?   @relation(fields: [agent_id], references: [id], onDelete: NoAction, onUpdate: NoAction)
  users       users?    @relation(fields: [user_id], references: [id], onDelete: NoAction, onUpdate: NoAction)

  @@index([agent_id], map: "idx_treasury_agent_id")
  @@index([category], map: "idx_treasury_category")
  @@index([user_id], map: "idx_treasury_user_id")
}

model users {
  id                     Int                     @id @default(autoincrement())
  email                  String                  @unique
  plan                   String?                 @default("solo")
  stripe_subscription_id String?
  created_at             DateTime?               @default(now()) @db.Timestamptz(6)
  updated_at             DateTime?               @default(now()) @db.Timestamptz(6)
  agents                 agents[]
  deployments            deployments[]
  model_metrics          model_metrics[]
  social_campaigns       social_campaigns[]
  treasury_transactions  treasury_transactions[]
}

model wallets {
  id                    Int       @id @default(autoincrement())
  address               String    @unique
  encrypted_private_key String
  balance_usdc          Decimal?  @default(0) @db.Decimal
  agent_id              Int?
  last_balance_check    DateTime? @db.Timestamptz(6)
  created_at            DateTime? @default(now()) @db.Timestamptz(6)
  agents                agents?   @relation(fields: [agent_id], references: [id], onDelete: Cascade, onUpdate: NoAction)

  @@index([agent_id], map: "idx_wallets_agent_id")
}

// Agent-to-Agent Bridge — private message bus for Atlas coordination
model bridge_messages {
  id         String   @id @default(cuid())
  sender     String   // "atlas-main", "atlas-agentbot", "eskyee"
  channel    String   @default("general") // general, tasks, alerts
  content    String   @db.Text
  priority   String   @default("normal") // normal, urgent, fyi
  read_by    String[] @default([])
  created_at DateTime @default(now()) @db.Timestamptz(6)

  @@index([channel], map: "idx_bridge_channel")
  @@index([sender], map: "idx_bridge_sender")
  @@index([created_at], map: "idx_bridge_created")
}

// ═══════════════════════════════════════════════════════
// JOB BOARD - Git City Integration
// ═══════════════════════════════════════════════════════

model JobCompany {
  id           String       @id @default(cuid())
  advertiserId String?
  name         String
  slug         String       @unique
  logoUrl      String?
  website      String
  description  String?
  githubOrg    String?
  hiredCount   Int          @default(0)
  createdAt    DateTime     @default(now())
  updatedAt    DateTime     @updatedAt
  jobs         JobListing[]
}

model JobListing {
  id              String        @id @default(cuid())
  companyId       String
  title           String
  description     String        @db.Text
  salaryMin       Int
  salaryMax       Int
  salaryCurrency  String        @default("USD")
  roleType        String
  techStack       String[]
  seniority       String
  contractType    String
  webType         String        @default("both")
  applyUrl        String
  language        String        @default("en")
  languagePtBr   String?
  badgeResponseGuaranteed Boolean @default(false)
  badgeNoAiScreening      Boolean @default(false)
  status          String        @default("draft")
  tier            String        @default("standard")
  rejectionReason String?
  stripeSessionId String?
  stripePaymentIntent String?
  viewCount       Int           @default(0)
  applyCount      Int           @default(0)
  profileCount   Int           @default(0)
  publishedAt     DateTime?
  expiresAt       DateTime?
  filledAt        DateTime?
  pausedAt        DateTime?
  createdAt       DateTime      @default(now())
  updatedAt       DateTime      @updatedAt
  company         JobCompany    @relation(fields: [companyId], references: [id], onDelete: Cascade)
  applications    JobApplication[]

  @@index([companyId])
  @@index([status])
  @@index([expiresAt])
}

model CareerProfile {
  id              String   @id @default(cuid())
  userId          String   @unique
  skills          String[]
  seniority       String
  yearsExperience Int?
  bio             String   @db.Text
  webType         String   @default("both")
  contractTypes   String[]
  salaryMin       Int?
  salaryMax       Int?
  salaryCurrency  String   @default("USD")
  salaryVisible   Boolean  @default(false)
  languages       String[]
  timezone        String?
  linkPortfolio   String?
  linkLinkedin    String?
  linkWebsite     String?
  openToWork      Boolean  @default(false)
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
}

model JobApplication {
  id          String      @id @default(cuid())
  listingId   String
  userId      String
  hasProfile  Boolean     @default(false)
  createdAt   DateTime    @default(now())
  listing     JobListing? @relation(fields: [listingId], references: [id])

  @@unique([listingId, userId])
  @@index([listingId])
  @@index([userId])
}

model JobAlert {
  id         String   @id @default(cuid())
  email      String
  skills     String[]
  seniority  String[]
  webType    String   @default("both")
  createdAt  DateTime @default(now())
  verified   Boolean  @default(false)
  verifyToken String?

  @@index([email])
}

// Usage tracking
model usage_logs {
  id            Int       @id @default(autoincrement())
  user_id       String
  agent_id      String
  model         String
  input_tokens  Int?      @default(0)
  output_tokens Int?      @default(0)
  cost_usd      Decimal?  @default(0) @db.Decimal(10, 6)
  endpoint      String?
  latency_ms    Int?
  success       Boolean?  @default(true)
  error_message String?
  created_at    DateTime? @default(now())

  @@index([user_id], map: "idx_usage_logs_user_id")
  @@index([agent_id], map: "idx_usage_logs_agent_id")
  @@index([created_at], map: "idx_usage_logs_created_at")
  @@index([user_id, created_at], map: "idx_usage_logs_user_created")
  @@index([agent_id, created_at], map: "idx_usage_logs_agent_created")
}
