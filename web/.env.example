
# Resend (Email)
RESEND_API_KEY=re_123456789

# x402 Payments (USDC on Base)
# Your wallet address to receive payments
X402_PAY_TO=0xYOUR_WALLET_ADDRESS_HEREYOUR_WALLET_ADDRESS_HERE
# Optional: custom facilitator URL
X402_FACILITATOR_URL=https://x402.org/facilitator

# Bankr API (for crypto trading)
BANKR_API_KEY=bk_...
BANKR_API_URL=https://api.bankr.bot

# AI Gateway (Video Generation)
AI_GATEWAY_API_KEY=your_ai_gateway_key

# Coinbase CDP (Wallet Integration)
# Get your API keys from https://portal.cdp.coinbase.com/
CDP_API_KEY_NAME=your-api-key-name
CDP_API_KEY_PRIVATE_KEY="-----BEGIN EC PRIVATE KEY-----\nYOUR_PRIVATE_KEY\n-----END EC PRIVATE KEY-----"

# Wallet Encryption Key (32 bytes hex)
# Generate with: openssl rand -hex 32
WALLET_ENCRYPTION_KEY=your-32-byte-hex-key-for-encrypting-wall
SOUL_SERVICE_URL=https://YOUR_SERVICE_URL
