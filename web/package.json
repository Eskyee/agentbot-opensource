{
  "name": "agentbot-web",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev",
    "build": "node_modules/.bin/prisma generate && next build",
    "start": "next start",
    "lint": "eslint . --ext .ts,.tsx,.js,.jsx --max-warnings 100",
    "test": "playwright test",
    "test:ui": "playwright test --ui",
    "design:check": "grep -rn 'gray-\\|purple-' app/ --include=\"*.tsx\" | grep -v node_modules || echo 'Design check passed'",
    "design:fix": "find app -name '*.tsx' -exec sed -i '' 's/bg-gray-/bg-zinc-/g; s/text-gray-/text-zinc-/g; s/border-gray-/border-zinc-/g; s/hover:bg-gray-/hover:bg-zinc-/g; s/bg-purple-/bg-blue-/g; s/text-purple-/text-blue-/g; s/border-purple-/border-blue-/g; s/hover:bg-purple-/hover:bg-blue-/g' {} +"
  },
